{
    "schemaVersion": 1,
    "id": "acornlib",
    "version": "${version}",
    "name": "AcornLib",
    "description": "A collection of helpful resources used in AcoYT's mods",
    "authors": [
        "AcoYT"
    ],
    "contributors": [
        "BouncingElf10"
    ],
    "license": "ARR",
    "icon": "assets/acornlib/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "net.acoyt.acornlib.impl.AcornLib"
        ],
        "client": [
            "net.acoyt.acornlib.impl.AcornLibClient"
        ],
        "fabric-datagen": [
            "net.acoyt.acornlib.data.AcornDatagen"
        ],
        "modmenu": [
            "net.acoyt.acornlib.compat.ModMenuCompat"
        ],
        "cardinal-components": [
            "net.acoyt.acornlib.impl.cca.AcornComponents"
        ]
    },
    "accessWidener": "acornlib.accesswidener",
    "mixins": [
        "acornlib.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.15.11",
        "minecraft": "~1.21.1",
        "java": ">=21",
        "fabric-api": "*"
    },
    "custom": {
        "modmenu": {
            "links": {
                "modmenu.youtube": "https://youtube.com/@AcoYTagain",
                "modmenu.modrinth": "https://modrinth.com/user/AcoYT"
            }
        },
        "cardinal-components": [
            "acornlib:data"
        ]
    }
}
