{
    "schemaVersion": 1,
    "id": "${id}",
    "version": "${version}",
    "name": "${name}",
    "description": "A collection of helpful resources used in AcoYT's mods!",
    "authors": [
        "AcoYT"
    ],
    "license": "ARR",
    "icon": "assets/acornlib/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "net.acoyt.acornlib.impl.AcornLib"
        ],
        "client": [
            "net.acoyt.acornlib.impl.AcornLibClient"
        ],
        "fabric-datagen": [
            "net.acoyt.acornlib.data.AcornDatagen"
        ],
        "cardinal-components": [
            "net.acoyt.acornlib.impl.cca.AcornComponents"
        ]
    },
    "mixins": [
        "acornlib.mixins.json"
    ],
    "accessWidener": "${access_widener}",
    "depends": {
        "fabricloader": ">=0.17",
        "minecraft": "${minecraft}"
    },
    "custom": {
        "cardinal-components": [
            "${components}"
        ]
    }
}
